# ============================================================
# .env.example - Template biến môi trường cho Backend Flask
# QUAN TRỌNG: Copy file này thành .env và điền giá trị thật!
# TUYỆT ĐỐI KHÔNG commit file .env lên Git!
# ============================================================

# ============================================================
# FLASK CONFIGURATION
# ============================================================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ============================================================
# DATABASE - Chọn một trong hai cách bên dưới
# ============================================================

# --- Cách 1: Dùng DATABASE_URL đầy đủ (ưu tiên - Render tự cung cấp) ---
# Render PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Neon.tech PostgreSQL:
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# --- Cách 2: Khai báo từng biến (local dev MySQL) ---
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cloak_link_db

# ============================================================
# CLOUDINARY - Lưu trữ ảnh bền vững (BẮT BUỘC cho Production)
# Đăng ký miễn phí tại: https://cloudinary.com
# Dashboard -> Settings -> Access Keys
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Tên thư mục lưu ảnh trên Cloudinary
CLOUDINARY_FOLDER=cloak_link_og_images

# ============================================================
# UPLOAD SETTINGS (chỉ dùng cho local fallback)
# ============================================================
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=10485760

# ============================================================
# CORS & URL
# ============================================================
# URL của Frontend (Vercel) - cần thiết cho CORS
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# URL gốc của Backend server
# Local dev: http://localhost:5000
# Production: https://your-app.onrender.com
BASE_URL=http://localhost:5000

# ============================================================
# TELEGRAM API
# ============================================================
# Dùng để lấy luồng video (stream) thay thế iframe Ok.ru (tùy chọn)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
